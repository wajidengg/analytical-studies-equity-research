import yfinance as yf
import pandas as pd
import numpy as np

def load_company_data(ticker: str):
    stock = yf.Ticker(ticker)

    data = {
        "info": stock.info,
        "financials": stock.financials,
        "balance_sheet": stock.balance_sheet,
        "cashflow": stock.cashflow,
        "history": stock.history(period="5y")
    }

    return data

def extract_features(data):
    info = data["info"]

    features = {
        "company": info.get("shortName"),
        "sector": info.get("sector"),
        "market_cap": info.get("marketCap"),
        "pe_ratio": info.get("trailingPE"),
        "forward_pe": info.get("forwardPE"),
        "price_to_book": info.get("priceToBook"),
        "profit_margin": info.get("profitMargins"),
        "operating_margin": info.get("operatingMargins"),
        "revenue_growth": info.get("revenueGrowth"),
        "earnings_growth": info.get("earningsGrowth"),
        "debt_to_equity": info.get("debtToEquity"),
        "roe": info.get("returnOnEquity")
    }

    return features

def interpret_features(f):
    interpretation = []

    # Valuation
    if f["pe_ratio"]:
        if f["pe_ratio"] < 15:
            interpretation.append("Valuation: Low P/E suggests potential undervaluation (context required).")
        elif f["pe_ratio"] > 30:
            interpretation.append("Valuation: High P/E suggests growth expectations are embedded.")

    # Profitability
    if f["profit_margin"]:
        if f["profit_margin"] > 0.2:
            interpretation.append("Profitability: Strong profit margins.")
        else:
            interpretation.append("Profitability: Moderate or weak margins.")

    # Debt risk
    if f["debt_to_equity"]:
        if f["debt_to_equity"] > 100:
            interpretation.append("Leverage: High debt levels may increase financial risk.")
        else:
            interpretation.append("Leverage: Manageable debt levels.")

    return interpretation

def generate_report(ticker, features, interpretation):
    report = f"""
# Analytical Study in Equity Research — {ticker}

---

## 1. Company Overview
Company: {features.get('company')}
Sector: {features.get('sector')}
Market Cap: {features.get('market_cap')}

---

## 2. Key Financial Metrics

- P/E Ratio: {features.get('pe_ratio')}
- Forward P/E: {features.get('forward_pe')}
- Price to Book: {features.get('price_to_book')}
- Profit Margin: {features.get('profit_margin')}
- Operating Margin: {features.get('operating_margin')}
- Revenue Growth: {features.get('revenue_growth')}
- Earnings Growth: {features.get('earnings_growth')}
- Debt to Equity: {features.get('debt_to_equity')}
- Return on Equity: {features.get('roe')}

---

## 3. Analytical Interpretation

"""

    for i in interpretation:
        report += f"- {i}\n"

    report += """

---

## 4. Key Observations (Initial View)

- This analysis is based on public financial aggregates.
- No forward forecasting or price prediction is included.
- Interpretation is conditional and not deterministic.

---

## 5. Limitations

- Data sourced from Yahoo Finance (may be incomplete or delayed)
- No SEC filing or transcript analysis yet
- No peer comparison or macro context included

---

## 6. Conclusion

This is a preliminary analytical snapshot intended for structured equity research development.

"""

    return report

ticker = "AAPL"

data = load_company_data(ticker)
features = extract_features(data)
interpretation = interpret_features(features)

report = generate_report(ticker, features, interpretation)

print(report)

with open(f"/content/{ticker}_study.md", "w") as f:
    f.write(report)
